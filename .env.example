# ──────────────────────────────────────────────────────────────────────────
# VayuAI environment variables — ALL OPTIONAL.
# The MVP runs with ZERO keys. Set these only to enrich the app (optional
# sources + LLM summaries). See README "Optional API keys" for details.
# Copy this file to `.env.local` and fill in the ones you have.
# ──────────────────────────────────────────────────────────────────────────

# --- Optional: LLM-generated daily summaries (PRD §5.1 Step 4) ---
# If set, daily summaries use the LLM instead of the deterministic template engine.
# If unset (default), summaries are generated by the template engine (always works).
ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# --- Optional: additional weather sources (PRD §4) ---
# These are NOT wired into the MVP by default (the 3 keyless sources are fused).
# Hooks for Phase 2: when set, OpenWeatherMap + WeatherAPI join the ensemble.
OPENWEATHERMAP_API_KEY=
WEATHERAPI_KEY=
